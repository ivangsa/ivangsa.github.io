{
  "fileTypes": ["zdl", "zw"],
  "name": "ZenWave Domain Language ZDL",
  "scopeName": "source.zdl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#imports" },
    { "include": "#legacyConstants" },
    { "include": "#aggregateDeclarations" },
    { "include": "#serviceDeclarations" },
    { "include": "#typeDeclarations" },
    { "include": "#apiDeclarations" },
    { "include": "#pluginDeclarations" },
    { "include": "#serviceMethods" },
    { "include": "#relationships" },
    { "include": "#fields" },
    { "include": "#configOptions" },
    { "include": "#withEvents" },
    { "include": "#standardTypes" },
    { "include": "#validators" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "begin": "/\\*\\*",
          "end": "\\*/",
          "name": "comment.block.documentation.zdl"
        },
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.zdl"
        },
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.zdl"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.zdl",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.zdl"
            }
          ]
        },
        {
          "begin": "'",
          "end": "'",
          "name": "string.quoted.single.zdl",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.zdl"
            }
          ]
        },
        {
          "begin": "/",
          "end": "/",
          "name": "string.regexp.zdl",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.zdl"
            }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "begin": "(@[a-zA-Z_][a-zA-Z0-9_]*)(\\()",
          "beginCaptures": {
            "1": { "name": "storage.type.annotation.zdl" },
            "2": { "name": "punctuation.definition.annotation-arguments.begin.java" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.definition.annotation-arguments.end.java" }
          },
          "name": "meta.declaration.annotation.zdl",
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#constants" },
            { "include": "#standardTypes" },
            {
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b\\s*(?=:)",
              "name": "constant.other.key.zdl"
            },
            {
              "match": "[:,\\[\\]{}|]",
              "name": "punctuation.separator.property.zdl"
            }
          ]
        },
        {
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*",
          "name": "storage.type.annotation.zdl"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "match": "(@import)(\\()",
          "captures": {
            "1": { "name": "keyword.declaration.zdl" },
            "2": { "name": "punctuation.definition.annotation-arguments.begin.java" }
          }
        },
        {
          "match": "\\b(import)\\b",
          "name": "keyword.declaration.zdl"
        }
      ]
    },
    "legacyConstants": {
      "patterns": [
        {
          "match": "^\\s*([A-Z0-9_]+)\\s*(=)\\s*(\\d+)\\b",
          "captures": {
            "1": { "name": "constant.other.key.zdl" },
            "2": { "name": "keyword.operator.assignment.zdl" },
            "3": { "name": "constant.numeric.zdl" }
          }
        }
      ]
    },
    "aggregateDeclarations": {
      "patterns": [
        {
          "match": "\\b(aggregate)\\s+([A-Z_][a-zA-Z0-9_]*)(\\()([A-Z_][a-zA-Z0-9_]*)(\\))",
          "captures": {
            "1": { "name": "keyword.declaration.zdl" },
            "2": { "name": "entity.name.type.zdl" },
            "3": { "name": "punctuation.section.parens.begin.zdl" },
            "4": { "name": "entity.name.type.zdl" },
            "5": { "name": "punctuation.section.parens.end.zdl" }
          }
        }
      ]
    },
    "serviceDeclarations": {
      "patterns": [
        {
          "match": "\\b(service)\\s+([A-Z_][a-zA-Z0-9_]*)(\\s+)(for)(\\s*)(\\()([^)]*)(\\))",
          "captures": {
            "1": { "name": "keyword.declaration.zdl" },
            "2": { "name": "entity.name.type.zdl" },
            "4": { "name": "keyword.control.zdl" },
            "6": { "name": "punctuation.section.parens.begin.zdl" },
            "7": {
              "patterns": [
                {
                  "match": "[A-Z_][a-zA-Z0-9_]*",
                  "name": "entity.name.type.zdl"
                },
                {
                  "match": ",",
                  "name": "punctuation.separator.comma.zdl"
                }
              ]
            },
            "8": { "name": "punctuation.section.parens.end.zdl" }
          }
        },
        {
          "match": "\\b(service)\\s+([A-Z_][a-zA-Z0-9_]*(?:\\s*,\\s*[A-Z_][a-zA-Z0-9_]*)*)\\s+(with)\\s+([A-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.zdl" },
            "2": { "name": "entity.name.type.zdl" },
            "3": { "name": "keyword.control.zdl" },
            "4": { "name": "entity.name.type.zdl" }
          }
        }
      ]
    },
    "typeDeclarations": {
      "patterns": [
        {
          "match": "\\b(entity|input|output|event|enum)\\s+([A-Z_][a-zA-Z0-9_]*)(?:\\s*(\\()([a-zA-Z_][a-zA-Z0-9_]*)(\\)))?",
          "captures": {
            "1": { "name": "keyword.declaration.zdl" },
            "2": { "name": "entity.name.type.zdl" },
            "3": { "name": "punctuation.section.parens.begin.zdl" },
            "4": { "name": "variable.other.field.zdl" },
            "5": { "name": "punctuation.section.parens.end.zdl" }
          }
        }
      ]
    },
    "apiDeclarations": {
      "patterns": [
        {
          "match": "\\b(asyncapi|openapi|zdl)\\s*(?:\\(([^)]*)\\))?\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.zdl" },
            "2": { "name": "variable.other.field.zdl" },
            "3": { "name": "entity.name.type.zdl" }
          }
        }
      ]
    },
    "pluginDeclarations": {
      "patterns": [
        {
          "match": "^\\s*(disabled)?\\s*([A-Z_][a-zA-Z0-9_]*Plugin|[A-Z_][a-zA-Z0-9_]*)(?:\\s*(\\()\\s*(inherit)\\s+(true|false)\\s*(\\)))?\\s*(?=\\{)",
          "captures": {
            "1": { "name": "keyword.declaration.zdl" },
            "2": { "name": "entity.name.type.zdl" },
            "3": { "name": "punctuation.section.parens.begin.zdl" },
            "4": { "name": "constant.other.key.zdl" },
            "5": { "name": "constant.language.zdl" },
            "6": { "name": "punctuation.section.parens.end.zdl" }
          }
        },
        {
          "match": "(--[a-zA-Z_][a-zA-Z0-9_-]*)(?:\\s*(=)\\s*([^\\s}]+))?",
          "captures": {
            "1": { "name": "support.type.property-name.zdl" },
            "2": { "name": "keyword.operator.assignment.zdl" },
            "3": { "name": "string.unquoted.zdl" }
          }
        }
      ]
    },
    "serviceMethods": {
      "patterns": [
        {
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)(\\()([^)]*)(\\))\\s*([A-Z_][a-zA-Z0-9_]*)(\\[\\])?(\\?)?",
          "captures": {
            "1": { "name": "support.function.zdl" },
            "2": { "name": "punctuation.section.parens.begin.zdl" },
            "3": {
              "patterns": [
                {
                  "match": "@natural",
                  "name": "storage.type.annotation.zdl"
                },
                {
                  "match": "\\bid\\??\\b",
                  "name": "variable.language.zdl"
                },
                {
                  "match": "[A-Z_][a-zA-Z0-9_]*\\??",
                  "name": "entity.name.type.zdl"
                },
                {
                  "match": ",",
                  "name": "punctuation.separator.comma.zdl"
                }
              ]
            },
            "4": { "name": "punctuation.section.parens.end.zdl" },
            "5": { "name": "entity.name.type.zdl" },
            "6": { "name": "keyword.operator.zdl" },
            "7": { "name": "keyword.operator.zdl" }
          }
        },
        {
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)(\\()([^)]*)(\\))",
          "captures": {
            "1": { "name": "support.function.zdl" },
            "2": { "name": "punctuation.section.parens.begin.zdl" },
            "3": {
              "patterns": [
                {
                  "match": "@natural",
                  "name": "storage.type.annotation.zdl"
                },
                {
                  "match": "\\bid\\??\\b",
                  "name": "variable.language.zdl"
                },
                {
                  "match": "[A-Z_][a-zA-Z0-9_]*\\??",
                  "name": "entity.name.type.zdl"
                },
                {
                  "match": ",",
                  "name": "punctuation.separator.comma.zdl"
                }
              ]
            },
            "4": { "name": "punctuation.section.parens.end.zdl" }
          }
        }
      ]
    },
    "relationships": {
      "patterns": [
        {
          "match": "\\b(relationship)\\s+(ManyToMany|ManyToOne|OneToMany|OneToOne)",
          "captures": {
            "1": { "name": "keyword.declaration.zdl" },
            "2": { "name": "keyword.declaration.zdl" }
          }
        },
        {
          "match": "\\b([A-Z_][a-zA-Z0-9_]*)(\\{)([a-zA-Z_][a-zA-Z0-9_]*)(?:\\(([^)]*)\\))?([^}]*)?(\\})\\s+(to)\\s+([A-Z_][a-zA-Z0-9_]*)(?:\\{([^}]*)\\})?",
          "captures": {
            "1": { "name": "entity.name.type.zdl" },
            "2": { "name": "punctuation.section.braces.begin.zdl" },
            "3": { "name": "variable.other.field.zdl" },
            "4": { "name": "variable.other.field.zdl" },
            "5": {
              "patterns": [
                { "include": "#validators" },
                { "include": "#constants" }
              ]
            },
            "6": { "name": "punctuation.section.braces.end.zdl" },
            "7": { "name": "keyword.control.zdl" },
            "8": { "name": "entity.name.type.zdl" },
            "9": {
              "patterns": [
                { "include": "#validators" },
                {
                  "match": "[a-zA-Z_][a-zA-Z0-9_]*",
                  "name": "variable.other.field.zdl"
                }
              ]
            }
          }
        }
      ]
    },
    "fields": {
      "patterns": [
        {
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)(\\s+)(String|Integer|Long|BigDecimal|Float|Double|Enum|Boolean|LocalDate|ZonedDateTime|Instant|Duration|UUID|Blob|AnyBlob|ImageBlob|TextBlob|byte|string|boolean|int|long|float|double)(\\[\\])?(\\?)?(?:\\s*(\\()([a-zA-Z_][a-zA-Z0-9_]*)(\\)))?(?:\\s*(=)\\s*([^\\s{]+))?",
          "captures": {
            "1": { "name": "variable.other.field.zdl" },
            "3": { "name": "entity.name.type.standard.zdl" },
            "4": { "name": "keyword.operator.zdl" },
            "5": { "name": "keyword.operator.zdl" },
            "6": { "name": "punctuation.section.parens.begin.zdl" },
            "7": { "name": "variable.other.field.zdl" },
            "8": { "name": "punctuation.section.parens.end.zdl" },
            "9": { "name": "keyword.operator.assignment.zdl" },
            "10": {
              "patterns": [
                { "include": "#strings" },
                { "include": "#constants" },
                {
                  "match": "[A-Z_][a-zA-Z0-9_]*(?:\\.[A-Z_][a-zA-Z0-9_]*)?",
                  "name": "constant.other.zdl"
                }
              ]
            }
          }
        },
        {
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)(\\s+)([A-Z_][a-zA-Z0-9_]*)(\\[\\])?(\\?)?(?:\\s*(\\()([a-zA-Z_][a-zA-Z0-9_]*)(\\)))?(?:\\s*(=)\\s*([^\\s{]+))?",
          "captures": {
            "1": { "name": "variable.other.field.zdl" },
            "3": { "name": "entity.name.type.zdl" },
            "4": { "name": "keyword.operator.zdl" },
            "5": { "name": "keyword.operator.zdl" },
            "6": { "name": "punctuation.section.parens.begin.zdl" },
            "7": { "name": "variable.other.field.zdl" },
            "8": { "name": "punctuation.section.parens.end.zdl" },
            "9": { "name": "keyword.operator.assignment.zdl" },
            "10": {
              "patterns": [
                { "include": "#strings" },
                { "include": "#constants" },
                {
                  "match": "[A-Z_][a-zA-Z0-9_]*(?:\\.[A-Z_][a-zA-Z0-9_]*)?",
                  "name": "constant.other.zdl"
                }
              ]
            }
          }
        },
        {
          "match": "\\b([A-Z_][A-Z0-9_]*)(?:\\((\\d+)\\))?\\s*,?",
          "captures": {
            "1": { "name": "constant.other.enum.zdl" },
            "2": { "name": "constant.numeric.zdl" }
          }
        }
      ]
    },
    "configOptions": {
      "patterns": [
        {
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)(\\s+)(?!for\\b|withEvents\\b)(?=\\S)",
          "captures": {
            "1": { "name": "support.type.property-name.zdl" }
          }
        }
      ]
    },
    "withEvents": {
      "patterns": [
        {
          "match": "\\b(withEvents)\\b",
          "name": "keyword.control.zdl"
        },
        {
          "match": "(\\[)([A-Z_][a-zA-Z0-9_]*(?:\\s*\\|\\s*[A-Z_][a-zA-Z0-9_]*)*)(\\])",
          "captures": {
            "1": { "name": "punctuation.section.brackets.begin.zdl" },
            "2": {
              "patterns": [
                {
                  "match": "[A-Z_][a-zA-Z0-9_]*",
                  "name": "entity.name.type.zdl"
                },
                {
                  "match": "\\|",
                  "name": "keyword.operator.zdl"
                }
              ]
            },
            "3": { "name": "punctuation.section.brackets.end.zdl" }
          }
        }
      ]
    },
    "standardTypes": {
      "patterns": [
        {
          "match": "\\b(String|Integer|Long|BigDecimal|Float|Double|Enum|Boolean|LocalDate|ZonedDateTime|Instant|Duration|UUID|Blob|AnyBlob|ImageBlob|TextBlob|byte|string|boolean|int|long|float|double)\\b",
          "name": "entity.name.type.standard.zdl"
        }
      ]
    },
    "validators": {
      "patterns": [
        {
          "match": "\\b(required|unique|min|max|minlength|maxlength|email|pattern)\\b",
          "name": "entity.name.tag.validation.zdl"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b(true|false|null|disabled|initial)\\b",
          "name": "constant.language.zdl"
        },
        {
          "match": "\\b\\d+(\\.\\d+)?\\b",
          "name": "constant.numeric.zdl"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(config|apis|plugins|policies|entity|enum|input|output|event|relationship|service|aggregate|for|from|to|with|withEvents|lifecycle|initial|asyncapi|openapi|zdl)\\b",
          "name": "keyword.control.zdl"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": "[{}()\\[\\],:|]",
          "name": "punctuation.separator.zdl"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.zdl"
        },
        {
          "match": "\\?",
          "name": "keyword.operator.zdl"
        }
      ]
    }
  }
}
