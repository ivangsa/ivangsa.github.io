---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import type { iconPaths } from '../../components/IconPaths';

type ProjectCard = {
	title: string;
	description: string;
	url: string;
	linkText: string;
	image?: string;
	coverImage?: string;
	icon?: keyof typeof iconPaths;
};

type ProjectGroup = {
	title: string;
	kicker: string;
	description: string;
	logo?: string;
	icon?: keyof typeof iconPaths;
	url: string;
	linkText: string;
	cards: ProjectCard[];
};

