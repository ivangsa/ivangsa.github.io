---
import { getCollection } from 'astro:content';
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';

const tutorials = (await getCollection('tutorials')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

function resolveImageSrc(path: string) {
	if (/^(https?:)?\/\//.test(path) || path.startsWith('/')) return path;
	return `/${path}`;
}

function hasPublicImage(path: string | undefined) {
	if (!path) return false;
	if (/^(https?:)?\/\//.test(path)) return true;
	const publicPath = path.startsWith('/') ? path.slice(1) : path;
	return existsSync(join(process.cwd(), 'public', publicPath));
}
---

<BaseLayout
	title="Hands-On Architecture | Ivan Garcia Sainz-Aja"
	description="Tutorials on Event-Driven Architecture, AsyncAPI, Kafka ecosystems, and domain-driven design."
>
	<main class="wrapper stack gap-8 list-page">
		<h1>Hands-On Architecture</h1>
		<ul class="items">
			{
				tutorials.map((tutorial) => (
					<li>
						<article class="item item-with-image">
							{hasPublicImage(tutorial.data.featuredImage) ? (
								<img
									class="item-image"
									src={resolveImageSrc(tutorial.data.featuredImage)}
									alt={tutorial.data.featuredImageAlt ?? ''}
									loading="lazy"
								/>
							) : (
								<div class="item-image-placeholder" aria-hidden="true"></div>
							)}
							<div class="item-body">
								<p class="meta">
									<time datetime={tutorial.data.date.toISOString()}>
										{tutorial.data.date.toLocaleDateString('en-US', {
											year: 'numeric',
											month: 'short',
											day: 'numeric',
										})}
									</time>
									{tutorial.data.featured && <span>Featured</span>}
								</p>
								<h2><a href={`/tutorials/${tutorial.id}/`}>{tutorial.data.title}</a></h2>
								<p>{tutorial.data.summary}</p>
							</div>
						</article>
					</li>
				))
			}
		</ul>
	</main>
</BaseLayout>

<style>
	.list-page {
		padding-bottom: 4rem;
	}

	h1 {
		font-size: var(--text-3xl);
	}

	.items {
		list-style: none;
		padding: 0;
		display: grid;
		gap: 1rem;
	}

	.item {
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 1rem;
		background: var(--gradient-subtle);
	}

	.item-with-image {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.875rem;
		align-items: start;
	}

	.item-image {
		width: 100%;
		height: 180px;
		object-fit: cover;
		border-radius: 0.5rem;
	}

	.item-image-placeholder {
		width: 100%;
		height: 180px;
		border-radius: 0.5rem;
		border: 1px dashed var(--gray-700);
		background: color-mix(in srgb, var(--gray-900) 55%, transparent);
	}

	.item-body {
		min-width: 0;
	}

	.meta {
		display: flex;
		gap: 0.75rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin-bottom: 0.25rem;
	}

	h2 {
		font-size: var(--text-xl);
		margin-bottom: 0.5rem;
	}

	h2 a {
		color: inherit;
		text-decoration: none;
	}

	p {
		color: var(--gray-300);
	}

	@media (min-width: 768px) {
		.item-with-image {
			grid-template-columns: minmax(160px, 220px) minmax(0, 1fr);
		}

		.item-image,
		.item-image-placeholder {
			height: 120px;
		}
	}
</style>

