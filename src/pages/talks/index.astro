---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const talks = (await getCollection('talks')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
	title="Talks | Ivan Garcia Sainz-Aja"
	description="Talks and workshops on AsyncAPI, Kafka, and event-driven architecture."
>
	<main class="wrapper stack gap-8 list-page">
		<h1>Talks</h1>
		<img src="/SpringIO-2025_800x533.jpg" alt="Spring I/O 2025" style="width: 100%; max-width: 800px; margin: 2rem auto; display: block; border-radius: 0.75rem;" />
		<ul class="items">
			{
				talks.map((talk) => (
					<li>
						<article class="item stack gap-2">
							<p class="meta">
								<time datetime={talk.data.date.toISOString()}>
									{talk.data.date.toLocaleDateString('en-US', {
										year: 'numeric',
										month: 'short',
										day: 'numeric',
									})}
								</time>
								{talk.data.featured && <span>Featured</span>}
							</p>
							<h2><a href={`/talks/${talk.id}/`}>{talk.data.title}</a></h2>
							<p>{talk.data.summary}</p>
							<div class="links">
								{talk.data.slides && <a href={talk.data.slides}>Slides</a>}
							</div>
						</article>
					</li>
				))
			}
		</ul>
	</main>
</BaseLayout>

<style>
	.list-page {
		padding-bottom: 4rem;
	}

	h1 {
		font-size: var(--text-3xl);
	}

	.items {
		list-style: none;
		padding: 0;
		display: grid;
		gap: 1rem;
	}

	.item {
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 1rem;
		background: var(--gradient-subtle);
	}

	.meta {
		display: flex;
		gap: 0.75rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	h2 {
		font-size: var(--text-xl);
	}

	h2 a {
		color: inherit;
		text-decoration: none;
	}

	p {
		color: var(--gray-300);
	}

	.links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}
</style>

