---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
	entry: CollectionEntry<'articles'>;
}

export async function getStaticPaths() {
	const entries = await getCollection('articles');
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

function resolveImageSrc(path: string) {
	if (/^(https?:)?\/\//.test(path) || path.startsWith('/')) return path;
	return `/${path}`;
}
---

<BaseLayout title={`${entry.data.title} | Articles`} description={entry.data.summary} canonical={entry.data.canonical}>
	<main class="wrapper stack gap-8 detail-page">
		<a href="/articles/" class="back-link">Back to articles</a>
		<header class="stack gap-2">
			<p class="meta">
				<time datetime={entry.data.date.toISOString()}>
					{entry.data.date.toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'short',
						day: 'numeric',
					})}
				</time>
			</p>
			<h1>{entry.data.title}</h1>
			<p>{entry.data.summary}</p>
			{entry.data.externalUrl && (
				<p class="external-link">
					Published at{' '}
					<a href={entry.data.externalUrl} target="_blank" rel="noopener noreferrer">
						{entry.data.externalSite ?? new URL(entry.data.externalUrl).hostname}
					</a>{' '}
					· <a href={entry.data.externalUrl} target="_blank" rel="noopener noreferrer">Read original ↗</a>
				</p>
			)}
			{entry.data.featuredImage && (
				<img
					class="article-image"
					src={resolveImageSrc(entry.data.featuredImage)}
					alt={entry.data.featuredImageAlt ?? ''}
					loading="lazy"
				/>
			)}
		</header>
		{!entry.data.externalOnly && (
			<article class="content">
				<Content />
			</article>
		)}
	</main>
</BaseLayout>

<style>
	.detail-page {
		padding-bottom: 4rem;
	}

	.back-link {
		font-size: var(--text-sm);
	}

	.meta {
		color: var(--gray-400);
	}

	h1 {
		font-size: var(--text-3xl);
	}

	header > p {
		color: var(--gray-300);
	}

	.article-image {
		width: auto;
		max-width: 100%;
		height: auto;
		border-radius: 0.75rem;
		margin-top: 0.75rem;
	}

	.external-link {
		color: var(--gray-300);
		font-size: var(--text-sm);
	}

	:global(.detail-page .content * + *) {
		margin-top: 1rem;
	}

	:global(.detail-page .content h2),
	:global(.detail-page .content h3),
	:global(.detail-page .content h4) {
		margin-top: 2rem;
	}

	:global(.detail-page .content h2) {
		font-size: var(--text-2xl);
	}

	:global(.detail-page .content h3) {
		font-size: var(--text-xl);
	}

	:global(.detail-page .content h4) {
		font-size: var(--text-lg);
	}
</style>
