---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
	entry: CollectionEntry<'articles'>;
}

export async function getStaticPaths() {
	const entries = (await getCollection('articles')).filter((entry) => !entry.data.draft);
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const isArcadiaArticle = entry.data.tags.some((tag) => tag.toLowerCase() === 'arcadia');
const backLinkHref = isArcadiaArticle ? '/articles/arcadia/' : '/articles/';
const backLinkText = isArcadiaArticle ? 'Back to Arcadia Editions series...' : 'Back to articles';
const articlePool = (await getCollection('articles'))
	.filter((article) => !article.data.draft)
	.filter((article) =>
		isArcadiaArticle
			? article.data.tags.some((tag) => tag.toLowerCase() === 'arcadia')
			: !article.data.tags.some((tag) => tag.toLowerCase() === 'arcadia'),
	)
	.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const currentArticleIndex = articlePool.findIndex((article) => article.id === entry.id);
const previousArticle = currentArticleIndex > 0 ? articlePool[currentArticleIndex - 1] : undefined;
const nextArticle =
	currentArticleIndex >= 0 && currentArticleIndex < articlePool.length - 1
		? articlePool[currentArticleIndex + 1]
		: undefined;

function resolveImageSrc(path: string) {
	if (/^(https?:)?\/\//.test(path) || path.startsWith('/')) return path;
	return `/${path}`;
}

function getArticleHref(article: CollectionEntry<'articles'>) {
	if (article.data.externalOnly && article.data.externalUrl) return article.data.externalUrl;
	return `/articles/${article.id}/`;
}
---

<BaseLayout title={`${entry.data.title} | Articles`} description={entry.data.summary} canonical={entry.data.canonical}>
	<main class="wrapper stack gap-8 detail-page">
		<a href={backLinkHref} class="back-link">{backLinkText}</a>
		<header class="stack gap-2">
			<p class="meta">
				<time datetime={entry.data.date.toISOString()}>
					{entry.data.date.toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'short',
						day: 'numeric',
					})}
				</time>
			</p>
			<h1>{entry.data.title}</h1>
			{entry.data.showSummaryInArticleBody && <p>{entry.data.summary}</p>}
			{entry.data.externalUrl && (
				<p class="external-link">
					Published at{' '}
					<a href={entry.data.externalUrl} target="_blank" rel="noopener noreferrer">
						{entry.data.externalSite ?? new URL(entry.data.externalUrl).hostname}
					</a>{' '}
					· <a href={entry.data.externalUrl} target="_blank" rel="noopener noreferrer">Read original ↗</a>
				</p>
			)}
			{entry.data.featuredImage && (
				<img
					class="article-image"
					src={resolveImageSrc(entry.data.featuredImage)}
					alt={entry.data.featuredImageAlt ?? ''}
					loading="lazy"
				/>
			)}
		</header>
		{!entry.data.externalOnly && (
			<article class="content">
				<Content />
			</article>
		)}
		{(previousArticle || nextArticle) && (
			<nav class="article-nav" aria-label="Article navigation">
				{previousArticle && (
					<a class="article-nav-link previous" href={getArticleHref(previousArticle)}>
						<span class="article-nav-title"><span class="article-nav-arrow">&larr;</span> {previousArticle.data.title}</span>
					</a>
				)}
				{nextArticle && (
					<a class="article-nav-link next" href={getArticleHref(nextArticle)}>
						<span class="article-nav-title">{nextArticle.data.title} <span class="article-nav-arrow">&rarr;</span></span>
					</a>
				)}
			</nav>
		)}
	</main>
</BaseLayout>

<style>
	.detail-page {
		padding-bottom: 4rem;
		max-width: 86ch;
	}

	.back-link {
		font-size: var(--text-sm);
	}

	.meta {
		color: var(--gray-400);
	}

	h1 {
		font-size: var(--text-3xl);
	}

	header > p {
		color: var(--gray-300);
	}

	.article-image {
		width: auto;
		max-width: 100%;
		height: auto;
		border-radius: 0.75rem;
		margin-top: 0.75rem;
	}

	.external-link {
		color: var(--link-color);
		font-size: var(--text-sm);
	}

	.article-nav {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		border-top: 1px solid var(--gray-800);
		padding-top: 2rem;
	}

	.article-nav-link {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		padding: 0.25rem 0;
		color: var(--link-color);
		text-decoration: underline;
		text-decoration-color: var(--link-color);
	}

	.article-nav-link:hover .article-nav-title {
		color: var(--accent-dark);
	}

	.article-nav-link.next {
		text-align: right;
	}

	.article-nav-arrow {
		color: var(--link-color);
		font-size: 1.3em;
		font-weight: 700;
	}

	.article-nav-title {
		color: var(--link-color);
		font-size: 1rem;
		font-weight: 400;
		line-height: 1.7;
		transition: color var(--theme-transition);
	}

	:global(.detail-page .content * + *) {
		margin-top: 1rem;
	}

	:global(.detail-page .content h2),
	:global(.detail-page .content h3),
	:global(.detail-page .content h4) {
		margin-top: 2rem;
	}

	:global(.detail-page .content h2) {
		font-size: var(--text-2xl);
	}

	:global(.detail-page .content h3) {
		font-size: var(--text-xl);
	}

	:global(.detail-page .content h4) {
		font-size: var(--text-lg);
	}

	@media (min-width: 50em) {
		.article-nav {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.article-nav-link.next {
			grid-column: 2;
		}
	}
</style>
