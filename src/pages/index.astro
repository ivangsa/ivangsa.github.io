---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import Skills from '../components/Skills.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const allArticles = (await getCollection('articles')).filter((article) => !article.data.draft);
const hasArcadiaTag = (article: (typeof allArticles)[number]) =>
	article.data.tags.some((tag) => tag.toLowerCase() === 'arcadia');

const allArticlesEn = allArticles
	.filter((a) => !a.data.lang || a.data.lang === 'en')
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const nonArcadiaArticlesEn = allArticlesEn.filter((article) => !hasArcadiaTag(article));
const arcadiaArticles = allArticlesEn.filter(hasArcadiaTag);

const featuredArticle = nonArcadiaArticlesEn.find((a) => a.data.featured) ?? nonArcadiaArticlesEn[0];
const latestArticles = nonArcadiaArticlesEn
	.filter((a) => a.id !== featuredArticle?.id)
	.slice(0, 2);
const arcadiaStartArticle = arcadiaArticles.find((article) => article.id.startsWith('arcadia/001-'));
const fixedArcadiaArticle = arcadiaArticles.find((article) => article.id.startsWith('arcadia/002-'));
const latestArcadiaStripArticles = arcadiaArticles
	.filter((article) => !article.id.startsWith('arcadia/001-') && !article.id.startsWith('arcadia/002-'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3)
	.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const arcadiaStripArticles = [fixedArcadiaArticle, ...latestArcadiaStripArticles].filter(
	(article): article is (typeof arcadiaArticles)[number] => article !== undefined,
);

function getArcadiaSequence(article: (typeof arcadiaArticles)[number]) {
	const sequence = article.id.match(/(?:^|\/)(\d+)/)?.[1];
	return sequence ? String(Number(sequence)).padStart(2, '0') : '';
}

const allTutorials = (await getCollection('tutorials')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const practicalExamples = allTutorials.slice(0, 3);

const articlesEs = allArticles
	.filter((a) => a.data.lang === 'es')
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

const talks = (await getCollection('talks'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
const projects = (await getCollection('projects'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
---

<BaseLayout
	title="Event Driven Architecture Expert | Ivan Garcia Sainz-Aja"
	description="Designing, governing, and evolving event-driven systems, with a focus on Kafka ecosystems, domain modeling, and API-driven workflows."
>
	<div class="stack gap-8 lg:gap-15">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
    title="I am Iván García Sainz-Aja."
    tagline="I am a programmer. That is where I start and where I always come back to."
    align="start"
>
    <p class="intro">
        I model event-driven architectures, design API governance at scale, and build the tools that make good architecture visible and automatable. Then I use those tools to build actual software.
    </p>

    <div class="actions">
        <a href="/projects/"><Pill><Icon icon="code" size="1.33em" /> Explore ZenWave360 &rarr;</Pill></a>
        <a href="/articles/"><Pill><Icon icon="pencil-line" size="1.33em" /> Read Articles &rarr;</Pill></a>
        <a href="/talks/"><Pill><Icon icon="microphone-stage" size="1.33em" /> Watch Talks &rarr;</Pill></a>
    </div>
</Hero>

				<picture>
					<source srcset="/profile-picture-569x854.avif" type="image/avif">
					<source srcset="/profile-picture-569x854.webp" type="image/webp">
					
					<img alt="Ivan Garcia Sainz-Aja" width="569" height="854" src="/profile-picture-569x854.png" loading="lazy"/>
				</picture>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-8 lg:gap-15">

			<section class="box arcadia-series stack gap-8">
				<div class="arcadia-hero">
					<img
						class="arcadia-hero-image"
						src="/assets/articles/arcadia-editions/arcadia.png"
						alt="Arcadia Editions"
						loading="lazy"
					/>
					<div class="arcadia-hero-body">
						<p class="arcadia-eyebrow">The Arcadia Editions Series</p>
						<h3>
							{arcadiaStartArticle ? (
								<a href={`/articles/${arcadiaStartArticle.id}/`}>The Fictional Company I Built to Explore Event-Driven Architecture</a>
							) : (
								'The Fictional Company I Built to Explore Event-Driven Architecture'
							)}
						</h3>
						<p>
							A fictional board game retailer built to explore event-driven architecture end-to-end.
							Domain discovery, flow modeling, API generation, and running Spring Boot services - all in the open.
						</p>
						<div class="arcadia-actions">
							{arcadiaStartArticle && (
								<a class="arcadia-cta" href={`/articles/${arcadiaStartArticle.id}/`}>Start from the beginning &rarr;</a>
							)}
							<a class="arcadia-cta arcadia-cta-secondary" href="/articles/arcadia/">View all articles</a>
						</div>
					</div>
				</div>
				<ul class="arcadia-strip">
					{
						arcadiaStripArticles.map((article) => (
							<li>
								<a class="arcadia-card" href={`/articles/${article.id}/`}>
									{article.data.featuredImage && (
										<img
											class="arcadia-card-image"
											src={article.data.featuredImage.startsWith('/') ? article.data.featuredImage : `/${article.data.featuredImage}`}
											alt={article.data.featuredImageAlt ?? ''}
											loading="lazy"
										/>
									)}
									<span class="arcadia-badge">#{getArcadiaSequence(article)}</span>
									<h3>{article.data.title}</h3>
									<time datetime={article.data.date.toISOString()}>
										{article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
									</time>
									<p>{article.data.summary}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="box stack gap-8">
				<div class="section-head">
					<h2>Latest Articles</h2>
					<a href="/articles/">View all</a>
				</div>
				<div class="articles-layout">
					{featuredArticle && (
						<div class="card featured">
							{featuredArticle.data.featuredImage && (
								<img
									class="card-image"
									src={featuredArticle.data.featuredImage}
									alt={featuredArticle.data.featuredImageAlt ?? ''}
									loading="lazy"
								/>
							)}
							<div class="card-tags">
								{featuredArticle.data.tags.slice(0, 3).map((tag) => (
									<span class="card-tag">#{tag}</span>
								))}
							</div>
							<h3><a href={`/articles/${featuredArticle.id}/`}>{featuredArticle.data.title}</a></h3>
							<div class="card-meta">
								<time datetime={featuredArticle.data.date.toISOString()}>
									{featuredArticle.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
								</time>
								{featuredArticle.data.readingTime && <span>· {featuredArticle.data.readingTime}</span>}
							</div>
							<p class="card-description">{featuredArticle.data.summary}</p>
							<a class="card-cta" href={`/articles/${featuredArticle.id}/`}>→ Read article</a>
						</div>
					)}
					<div class="latest-stack">
						{latestArticles.map((article) => (
							<div class="card">
								{article.data.featuredImage && (
									<img
										class="card-image"
										src={article.data.featuredImage}
										alt={article.data.featuredImageAlt ?? ''}
										loading="lazy"
									/>
								)}
								<div class="card-tags">
									{article.data.tags.slice(0, 3).map((tag) => (
										<span class="card-tag">#{tag}</span>
									))}
								</div>
								<h3><a href={`/articles/${article.id}/`}>{article.data.title}</a></h3>
								<div class="card-meta">
									<time datetime={article.data.date.toISOString()}>
										{article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
									</time>
									{article.data.readingTime && <span>· {article.data.readingTime}</span>}
								</div>
								<p class="card-description">{article.data.summary}</p>
								<a class="card-cta" href={`/articles/${article.id}/`}>→ Read article</a>
							</div>
						))}
					</div>
				</div>
			</section>


			<section class="box stack gap-8">
				<div class="section-head">
					<h2>Practical Examples</h2>
					<a href="/tutorials/">View all</a>
				</div>
				<ul class="card-grid">
					{
						practicalExamples.map((tutorial) => (
							<li class="card">
								{tutorial.data.featuredImage && (
									<img
										class="card-image"
										src={tutorial.data.featuredImage}
										alt={tutorial.data.featuredImageAlt ?? ''}
										loading="lazy"
									/>
								)}
								<div class="card-tags">
									{tutorial.data.tags.slice(0, 3).map((tag) => (
										<span class="card-tag">#{tag}</span>
									))}
								</div>
								<h3><a href={`/tutorials/${tutorial.id}/`}>{tutorial.data.title}</a></h3>
								<div class="card-meta">
									<time datetime={tutorial.data.date.toISOString()}>
										{tutorial.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
									</time>
									{tutorial.data.readingTime && <span>· {tutorial.data.readingTime}</span>}
								</div>
								<p class="card-description">{tutorial.data.summary}</p>
								<a class="card-cta" href={`/tutorials/${tutorial.id}/`}>→ Read tutorial</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="box stack gap-8">
				<div class="section-head">
					<h2>Recent Talks</h2>
					<a href="/talks/">View all</a>
				</div>
				<ul class="card-grid">
					{
						talks.map((talk) => (
							<li class="card">
								<div class="card-tags">
									{talk.data.tags.slice(0, 3).map((tag) => (
										<span class="card-tag">#{tag}</span>
									))}
								</div>
								<h3><a href={`/talks/${talk.id}/`}>{talk.data.title}</a></h3>
								<div class="card-meta">
									<time datetime={talk.data.date.toISOString()}>
										{talk.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
									</time>
									{talk.data.duration && <span>· {talk.data.duration}</span>}
								</div>
								<p class="card-description">{talk.data.summary}</p>
								<a class="card-cta" href={`/talks/${talk.id}/`}>→ Watch talk</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="box stack gap-8">
				<div class="section-head">
					<h2>Artículos en Español</h2>
					<a href="/articles/">Ver todos</a>
				</div>
				<ul class="card-grid">
					{
						articlesEs.map((article) => (
							<li class="card">
								<div class="card-tags">
									{article.data.tags.slice(0, 3).map((tag) => (
										<span class="card-tag">#{tag}</span>
									))}
								</div>
								<h3><a href={`/articles/${article.id}/`}>{article.data.title}</a></h3>
								<div class="card-meta">
									<time datetime={article.data.date.toISOString()}>
										{article.data.date.toLocaleDateString('es-ES', { year: 'numeric', month: 'short' })}
									</time>
									{article.data.readingTime && <span>· {article.data.readingTime}</span>}
								</div>
								<p class="card-description">{article.data.summary}</p>
								<a class="card-cta" href={`/articles/${article.id}/`}>→ Leer artículo</a>
							</li>
						))
					}
				</ul>
			</section>
	</main>

	<ContactCTA />
	</div>
</BaseLayout>

<style>
	header.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	header.hero img {
		aspect-ratio: 3 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	.hero {
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.25rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	.eyebrow {
		font-size: var(--text-sm);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--gray-400);
	}

	h1 {
		font-size: var(--text-3xl);
	}

	.subtitle {
		font-size: var(--text-lg);
		max-width: 70ch;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.actions a {
		text-decoration: none;
		/* padding: 0.7rem 1rem; */
	}

	.intro {
		color: var(--gray-300);
		max-width: 74ch;
	}

	.box {
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 1.5rem;
		background-color: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
	}

	.focus-grid {
		display: grid;
		gap: 0.75rem;
		padding-inline-start: 1rem;
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}

	.section-head h2 {
		font-size: var(--text-2xl);
	}

	.card-grid {
		list-style: none;
		padding: 0;
		display: grid;
		gap: 1rem;
	}

	.articles-layout {
		display: grid;
		gap: 1rem;
		grid-template-columns: 1fr;
	}

	.latest-stack {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.latest-stack .card {
		flex: 1;
	}

	.card {
		padding: 1rem 1.25rem 1.25rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		background: var(--gradient-subtle);
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.card-image {
		width: 100%;
		height: 16 / 9;
		object-fit: cover;
		border-radius: 0.5rem;
		margin-bottom: 0.25rem;
	}

	.card.featured .card-description {
		-webkit-line-clamp: 4;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		margin-bottom: 0.125rem;
	}

	.card-tag {
		font-size: 0.7rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--accent-text-over);
		border: 1px solid var(--accent-regular);
		background-color: var(--accent-regular);
		border-radius: 999px;
		padding: 0.125rem 0.5rem;
		line-height: 1.6;
		white-space: nowrap;
	}

	.card h3 {
		font-size: var(--text-lg);
		margin: 0;
		line-height: 1.25;
	}

	.card h3 a {
		text-decoration: none;
		color: inherit;
	}

	.card h3 a:hover {
		color: var(--accent-dark);
	}

	.card-meta {
		display: flex;
		gap: 0.375rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin: 0;
	}

	.card-description {
		overflow: hidden;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		color: var(--gray-400);
		font-size: var(--text-sm);
		margin: 0;
	}

	.card-cta {
		display: inline-block;
		margin-top: 0.5rem;
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--accent-regular);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.card-cta:hover {
		color: var(--accent-dark);
	}

	.arcadia-series {
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--accent-regular) 16%, transparent), transparent 38%),
			var(--gray-999_40);
	}

	.arcadia-hero {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.25rem;
		align-items: center;
	}

	.arcadia-hero-image {
		width: 100%;
		max-height: 320px;
		aspect-ratio: 16 / 9;
		object-fit: contain;
		border-radius: 0.75rem;
		border: 1px solid var(--gray-800);
		background: white;
	}

	.arcadia-hero-body {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.75rem;
		width: 100%;
		min-width: 0;
	}

	.arcadia-eyebrow {
		margin: 0;
		color: var(--accent-regular);
		font-size: var(--text-base);
		font-weight: 700;
		text-transform: uppercase;
	}

	.arcadia-hero-body h3 {
		display: block;
		overflow: visible;
		width: 100%;
		margin: 0;
		max-width: 100%;
		font-size: var(--text-2xl);
		line-height: 1.1;
		white-space: normal;
		-webkit-line-clamp: unset;
		-webkit-box-orient: initial;
	}

	.arcadia-hero-body h3 a {
		color: var(--gray-0);
		text-decoration: none;
	}

	.arcadia-hero-body h3 a:hover,
	.arcadia-hero-body h3 a:focus-visible {
		color: var(--accent-dark);
	}

	.arcadia-hero-body p:not(.arcadia-eyebrow) {
		width: 100%;
		margin: 0;
		max-width: 100%;
		color: var(--gray-300);
	}

	.arcadia-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}

	.arcadia-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 7.5rem;
		border: 1px solid var(--accent-regular);
		border-radius: 999px;
		padding: 0.65rem 1rem;
		color: var(--accent-text-over);
		background: var(--accent-regular);
		font-weight: 700;
		text-decoration: none;
	}

	.arcadia-cta-secondary {
		border-color: color-mix(in srgb, var(--accent-regular) 70%, var(--gray-700));
		color: var(--gray-200);
		background: color-mix(in srgb, var(--gray-999) 65%, transparent);
	}

	.arcadia-cta-secondary:hover {
		color: var(--accent-text-over);
		background: var(--accent-regular);
	}

	.arcadia-strip {
		list-style: none;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
		gap: 1rem;
	}

	.arcadia-card {
		position: relative;
		display: flex;
		min-height: 100%;
		flex-direction: column;
		gap: 0.375rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 0.75rem;
		background: var(--gradient-subtle);
		color: inherit;
		text-decoration: none;
	}

	.arcadia-card:hover h3 {
		color: var(--accent-dark);
	}

	.arcadia-card-image {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: 0.5rem;
		margin-bottom: 0.25rem;
	}

	.arcadia-badge {
		position: absolute;
		top: 1rem;
		left: 1rem;
		border: 1px solid var(--accent-regular);
		border-radius: 999px;
		padding: 0.125rem 0.5rem;
		color: var(--accent-text-over);
		background: var(--accent-regular);
		font-size: 0.75rem;
		font-weight: 800;
		line-height: 1.5;
	}

	.arcadia-card h3 {
		overflow: hidden;
		display: -webkit-box;
		margin: 0.25rem 0 0;
		font-size: var(--text-sm);
		line-height: 1.2;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
	}

	.arcadia-card time {
		color: var(--gray-400);
		font-size: 0.75rem;
	}

	.arcadia-card p {
		overflow: hidden;
		display: -webkit-box;
		margin: 0;
		color: var(--gray-400);
		font-size: 0.75rem;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
	}

	@media (min-width: 50em) {
		.box {
			border-radius: 1.5rem;
			padding: 2.5rem;
		}

		header.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		header.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}

		h1 {
			font-size: var(--text-5xl);
		}

		.card-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.articles-layout {
			grid-template-columns: 2fr 1fr;
		}

		.arcadia-hero {
			grid-template-columns: minmax(240px, 360px) minmax(0, 1fr);
			gap: 2rem;
		}

		.arcadia-hero-image {
			height: 100%;
			max-height: 340px;
		}

		.arcadia-strip {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}

